# Required — used for synthetic user, judge, embeddings, generator, capture
OPENAI_API_KEY=your-openai-api-key-here

# Optional — used if judge model is set to a Claude model in dryrun.yaml
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Qdrant connection (defaults shown)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Logging
DRYRUN_LOG_LEVEL=INFO
